{
  "name": "clinic-saas",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24.18.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "db:generate": "pnpm --filter @clinic-saas/db db:generate",
    "db:migrate": "pnpm --filter @clinic-saas/db db:migrate",
    "db:studio": "pnpm --filter @clinic-saas/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^6.0.3"
  }
}
