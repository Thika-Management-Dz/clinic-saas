{
  "name": "clinic-saas",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24.18.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "test:scripts": "bash tests/test-setup-workstation.sh",
    "db:generate": "pnpm --filter @clinic-saas/db db:generate",
    "db:migrate": "pnpm --filter @clinic-saas/db db:migrate",
    "db:studio": "pnpm --filter @clinic-saas/db db:studio"
  },
  "devDependencies": {
    "@clinic-saas/eslint-config": "workspace:*",
    "@eslint/js": "^10.0.0",
    "@next/eslint-plugin-next": "^16.0.0",
    "eslint": "^10.6.0",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import-x": "^4.17.1",
    "globals": "^16.0.0",
    "turbo": "^2.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
