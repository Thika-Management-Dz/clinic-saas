{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    "schedule:earlyMondays"
  ],
  "timezone": "Africa/Algiers",
  "rangeStrategy": "bump",
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "all non-major",
      "automerge": false,
      "automergeType": "pr"
    },
    {
      "matchDepTypes": ["devDependencies"],
      "automerge": false
    },
    {
      "matchPackageNames": ["next", "react", "react-dom", "drizzle-orm", "@better-auth/frontend", "@trpc/server", "@trpc/client", "nestjs"],
      "extends": ["schedule:monthly"],
      "labels": ["major"]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
