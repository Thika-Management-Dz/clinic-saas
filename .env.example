# .env.example
#
# Template for environment variables required by the Clinic Management SaaS
# project. Copy to .env.local and fill in real values:
#
#   cp .env.example .env.local && $EDITOR .env.local
#
# .env.local is gitignored (see .gitignore: .env, .env.local, .env.*.local)
# — it will NEVER be committed. Only .env.example is committed.
#
# This file is organized by phase so you can fill in only what your current
# phase needs. Phase-tagged comments tell you when each var becomes required.
#
# SECURITY: Never paste real secrets into this file. This file is a TEMPLATE
# committed to a PUBLIC repo. Real values go in .env.local only.
# If you accidentally commit a real secret, rotate it immediately and
# follow docs/runbooks/breach-response.md.

# =============================================================================
# Phase 1 — CLI auth (token-based, for headless AI-agent sandboxes)
# =============================================================================
# These replace the browser-based `vercel login` / `doppler login` /
# `wrangler login` flows in Roadmap §1.7, which are impossible in a headless
# sandbox. Each CLI reads its token from the env var natively.

# GitHub PAT — used by gh CLI for PR/issue/ruleset operations and by git
# for private repo access (if ever switched to private).
# Scopes needed: repo, workflow, admin:org (for org-level ruleset ops).
# Create at: https://github.com/settings/tokens (classic) or fine-grained equiv.
# ROTATE after every chat session where this token is shared.
GH_TOKEN=

# Vercel — deploy previews and prod, manage env vars via `vercel env`.
# Create at: https://vercel.com/account/tokens (scope: clinic-saas project).
VERCEL_TOKEN=

# Doppler — secrets manager CLI. Per ADR-011, the project does NOT use Doppler
# as the canonical secret store for now: Service Tokens (the headless workflow)
# require the Doppler Team plan (~$99/mo), and the project is on the free
# Developer plan. Local dev + staging use gitignored .env files (see
# .env.example / .env.staging.example); CI (Phase 7) will use GitHub Actions
# encrypted secrets. The Doppler CLI is still installed per Roadmap §1.5.2,
# and `doppler login` (browser OAuth) still works on the operator's local
# machine — we are only declining the headless service-token workflow.
# This token is unused at runtime; left here for forward compatibility if
# the operator upgrades to Doppler Team in a future phase.
DOPPLER_TOKEN=

# Cloudflare — used for R2 (object storage for medical images / backups)
# and optionally for Durable Objects / Pages. Wrangler reads this natively.
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Suggested template: "Edit Cloudflare Workers" + R2 read/write.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Sentry — error tracking + source map upload. The CLI reads this natively.
# Create at: https://sentry.io/settings/account/api/auth-tokens/
# Scopes needed: org:read, project:releases (for source map upload).
SENTRY_AUTH_TOKEN=


# =============================================================================
# Phase 4 — Database (Postgres 17, local dev + parity tests)
# =============================================================================
# Local Postgres for dev. Run `docker compose up -d` to start Postgres 17
# (plus Redis 7 and Orthanc) — see docker-compose.yml at the repo root.
#
# Two connection strings are required for RLS correctness (ADR-001):
#
# 1. DATABASE_URL — the APP connection. Connects as `app_role` which has
#    NOBYPASSRLS, so RLS policies are enforced on every query. This is
#    what apps/api, apps/worker, and apps/web use at runtime.
DATABASE_URL=postgresql://app_role:dev_password@localhost:5432/clinic_dev
#
# 2. MIGRATION_DATABASE_URL — the MIGRATION connection. Connects as
#    `ops_superuser` which has BYPASSRLS, so migrations can CREATE TABLE,
#    CREATE POLICY, and insert seed data without RLS blocking them.
#    Used by: pnpm db:migrate. The drizzle.config.ts reads this var
#    (falling back to DATABASE_URL if unset).
MIGRATION_DATABASE_URL=postgresql://ops_superuser:dev_ops_password@localhost:5432/clinic_dev
#
# Both passwords above (dev_password, dev_ops_password) are dev-only defaults
# that match packages/db/sql/001_roles.sql. They are NOT secrets — they are
# committed because the dev environment is non-sensitive. For any non-local
# environment (staging, production), rotate both passwords and store the real
# values in a gitignored .env file (staging: .env.staging, see ADR-011 Tier 1)
# or in GitHub Actions encrypted secrets (CI, Phase 7 — see ADR-011 Tier 2).
# Production (Phase 16) uses on-host .env + systemd LoadCredential (ADR-011 Tier 3).

# Better-auth session secret. Generate with: openssl rand -base64 32
# MUST be the same value across all apps in the monorepo (web, api, worker).
BETTER_AUTH_SECRET=


# =============================================================================
# Phase 5 — Auth (better-auth)
# =============================================================================
# Public URL of the web app. In dev: http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000


# =============================================================================
# Phase 8 — Offline sync (PowerSync)
# =============================================================================
# PowerSync service URL + token. Only required once the offline-first sync
# layer is implemented. Leave empty until Phase 8.
POWERSYNC_URL=
POWERSYNC_TOKEN=


# =============================================================================
# Phase 9 — Notifications (SMS + email)
# =============================================================================
# SMS provider — Algerian regulations require an in-country provider for
# medical SMS. The blueprint's default is a local provider; leave empty
# until Phase 9.
SMS_PROVIDER_API_KEY=
SMS_PROVIDER_SENDER_ID=

# Email — Resend is the default. Create at: https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM="Clinic SaaS <noreply@yourdomain>"


# =============================================================================
# Phase 10 — Medical imaging (Orthanc)
# =============================================================================
# Orthanc is a self-hosted DICOM server. The repo's docker-compose will
# spin up a local instance for dev. Leave empty until Phase 10.
ORTHANC_URL=http://localhost:8042
ORTHANC_USERNAME=
ORTHANC_PASSWORD=


# =============================================================================
# Phase 13 — Payments (CIB / Edahabia)
# =============================================================================
# Algerian payment gateways. Leave empty until Phase 13.
PAYMENT_GATEWAY_MERCHANT_ID=
PAYMENT_GATEWAY_API_KEY=
PAYMENT_GATEWAY_WEBHOOK_SECRET=


# =============================================================================
# Phase 15 — Observability (production only — sandbox ignores)
# =============================================================================
# Per ADR-011 Tier 3, production secrets are injected via on-host .env +
# systemd LoadCredential (NOT Doppler). Local dev uses the SENTRY_AUTH_TOKEN
# above for source map upload only.
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=


# =============================================================================
# Phase 16 — Deployment (production only)
# =============================================================================
# Used only by deploy scripts. Sandboxes leave these empty.
DEPLOY_TARGET=              # one of: vercel, self-hosted
DEPLOY_ENVIRONMENT=         # one of: staging, production
